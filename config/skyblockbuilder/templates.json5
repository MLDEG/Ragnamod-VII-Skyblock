{
  // The template which will be used for spawn only
  // Example: 
  // {
  //     "name": "default",
  //     "desc": "",
  //     "file": "default.nbt",
  //     "spawns": "default",
  //     "direction": "south"
  // }
  "spawn": null,
  
  "spawns": {
    "classic": [
      [ 3, 3, 1 ]
    ]
  },
  
  // The list of templates being available. The first entry is the default template.
  "templates": [
    {
      "name": "Classic",
      "desc": "Default spawn",
      "file": "classic.nbt",
      "spawns": "classic",
      "direction": "south"
    }
  ]
}
